BOT_TOKEN=
SUPABASE_URL=
SUPABASE_KEY=
ADMIN_IDS=  # через запятую, telegram user_id администраторов
NOTIFY_SECRET=    # любая случайная строка, например uuid4; совпадает с VITE_NOTIFY_SECRET в .env
# Для Render используй Session pooler (IPv4), прямой db.<ref>.supabase.co — только IPv6:
# postgresql://postgres.<ref>:[password]@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres
